{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "make-with-options",
      "type": "shell",
      "command": "mingw32-make ${input:makeTarget} ${input:makeExtraArgs}",
      "options": {
        "cwd": "${fileDirname}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "makeTarget",
      "type": "promptString",
      "description": "Make target",
      "default": "all"
    },
    {
      "id": "makeExtraArgs",
      "type": "promptString",
      "description": "Extra make options/variables (optional)",
      "default": ""
    }
  ]
}
